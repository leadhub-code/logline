  "description": "Operational metrics for the logline agents and servers, exported over OTLP. Agents are distinguished by host_name; every process (agent or server) carries a unique service_instance_id. Server deployments sharing a host are told apart by service_namespace, and the reuse_port containers within a group by a stable service_instance_index (both set via OTEL_RESOURCE_ATTRIBUTES per container). Metric names assume the OpenTelemetry collector's Prometheus naming (unit and _total suffixes) and delta->cumulative conversion.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "logline",
    "otel"
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "eerjmty8wjhmof"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(logline_agent_files_watched_ratio, host_name)",
        "query": {
          "qryType": 1,
          "query": "label_values(logline_agent_files_watched_ratio, host_name)",
          "refId": "host"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "namespace",
        "label": "Server namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(logline_server_connections_total, service_namespace)",
        "query": {
          "qryType": 1,
          "query": "label_values(logline_server_connections_total, service_namespace)",
          "refId": "namespace"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "instance",
        "label": "Server instance (index)",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(logline_server_active_connections{service_namespace=~\"$namespace\"}, service_instance_index)",
        "query": {
          "qryType": 1,
          "query": "label_values(logline_server_active_connections{service_namespace=~\"$namespace\"}, service_instance_index)",
          "refId": "instance"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      }
    ]
  },
