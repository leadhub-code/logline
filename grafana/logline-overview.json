        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "max(logline_agent_shipping_lag_bytes{host_name=~\"$host\"})",
          "legendFormat": "max lag"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Throughput — read vs wire",
      "description": "Uncompressed bytes read from tailed files vs compressed bytes put on the wire. The gap is compression effectiveness.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(logline_agent_bytes_read_total{host_name=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "read (uncompressed)"
